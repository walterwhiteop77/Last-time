# ── Required ── set ALL of these in Render → Environment ─────────────────────
BOT_TOKEN=123456:ABCdef_from_BotFather
API_ID=12345678
API_HASH=your_api_hash_from_my.telegram.org
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/

# ── Session ── run setup_session.py locally first, then paste the output here ─
# python setup_session.py   →   copy the printed SESSION_STRING
SESSION_STRING=

# ── Optional ──────────────────────────────────────────────────────────────────
# PORT is injected by Render automatically — do not set manually
